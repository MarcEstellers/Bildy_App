Content-Type: {{contentType}}

{
    "email": "pablo.test.1@example.com",
    "password": "Password123!"
}


############################################################
# 4. ONBOARDING - DATOS PERSONALES (Punto 4a)
############################################################
PUT {{baseUrl}}/user/register
Content-Type: {{contentType}}
Authorization: Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJfaWQiOiI2OWQ0NTQ4MmExZGU1ZWIxMmM0NjM3MjEiLCJyb2xlIjoiYWRtaW4iLCJpYXQiOjE3NzU1MjMxMjUsImV4cCI6MTc3NTUyNDAyNX0.F666tpkPPJIBPZivVrQWm_-Ksjnm7OBiGeNg1_2eBGU


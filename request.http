############################################################
# 8. GESTIÓN DE SESIÓN (Punto 7)
############################################################
### REFRESH TOKEN
POST {{baseUrl}}/user/refresh
Content-Type: {{contentType}}

{
    "refreshToken": "{{refreshToken}}"
}

### LOGOUT
POST {{baseUrl}}/user/logout
Authorization: Bearer {{token}}


############################################################
# 9. CAMBIAR CONTRASEÑA (Punto 9)
############################################################
PUT {{baseUrl}}/user/password
Content-Type: {{contentType}}
Authorization: Bearer {{token}}

{
    "currentPassword": "Password123!",
    "newPassword": "NuevaPassword456!"
}


############################################################
# 10. INVITAR COMPAÑEROS (Punto 10)
############################################################
POST {{baseUrl}}/user/invite
Content-Type: {{contentType}}
Authorization: Bearer {{token}}

{
    "email": "empleado@example.com",
    "password": "Password123!"
}


############################################################
# 11. ELIMINAR USUARIO (Punto 8)
############################################################
### SOFT DELETE
DELETE {{baseUrl}}/user?soft=true
Authorization: Bearer {{token}}

### HARD DELETE (Si quieres borrarlo del todo)
# DELETE {{baseUrl}}/user?soft=false
# Authorization: Bearer {{token}}
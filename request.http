### VARIABLES CONFIGURACIÓN
@baseUrl = http://localhost:3000/api
@contentType = application/json

# Nota: Copia el access_token aquí después del Login/Registro
@token = TU_ACCESS_TOKEN_AQUI
# Nota: Copia el refresh_token aquí para probar el punto 7
@refreshToken = TU_REFRESH_TOKEN_AQUI

############################################################
# 1. REGISTRO DE USUARIO (Punto 1)
############################################################
# @name register
POST {{baseUrl}}/user/register
Content-Type: {{contentType}}

{
   "email": "pablo.test.1@example.com",
    "password": "Password123!"
}

### PRUEBA ERROR 409 (Email duplicado)
POST {{baseUrl}}/user/register
Content-Type: {{contentType}}

{
    "email": "pablo.test.1@example.com",
    "password": "Password123!"
}


############################################################
